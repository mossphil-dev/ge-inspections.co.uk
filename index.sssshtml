    <!-- main Section -->
    <div class="wrapper">
        <div class="main-content">
            <div class="main-image-area">
                <img class="main-image" src="images/tractor1.jpeg" alt="">
            </div>
            <div class="main-text-area">
                <h1 class="main-text-right">Welcome</h1>

                <p class="main-text-right"> Whether you just need a one-off inspection or require us to carry out
                    thorough
                    examinations on a range of lifting plant, pressure systems or work equipment on a scheduled program
                    to help you achieve your compliance in a timely and friendly service.</p><br><br>
                <p class="main-text-right"> At GEI we have an extensive experience and have provided our services within
                    many
                    industrial sectors including:</p><br>



                <ul class="list-style">
                    <li>AGRICULTURAL</li>
                    <li>LOGISTICAL & TRANSPORT</li>
                    <li>CONSTRUCTION</li>
                    <li>PLANT HIRE</li>
                    <li>MANUFACTURING</li>
                    <li>ENGINEERING & TECHNICAL SERVICES</li>
                    <li>FOOD PRODUCTION</li>
                    <li>ADMINISTRATIVE PREMISES</li>
                    <li>HOSPITALITY</li>
                </ul>

            </div>

        </div>
    </div>
